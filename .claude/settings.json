{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_EXEC_LAUNCH_DIR\"/hooks/run-linter.py linters/exception_safety_linter.py" },
          { "type": "command", "command": "\"$CLAUDE_EXEC_LAUNCH_DIR\"/hooks/run-linter.py linters/reexport_linter.py" },
          { "type": "command", "command": "\"$CLAUDE_EXEC_LAUNCH_DIR\"/hooks/run-linter.py linters/strict_typing_linter.py" },
          { "type": "command", "command": "\"$CLAUDE_EXEC_LAUNCH_DIR\"/hooks/run-linter.py linters/suppression_rationale_linter.py" },
          { "type": "command", "command": "\"$CLAUDE_EXEC_LAUNCH_DIR\"/hooks/run-linter.py linters/uv_script_linter.py" },
          { "type": "command", "command": "\"$CLAUDE_EXEC_LAUNCH_DIR\"/hooks/run-ruff.py" }
        ]
      }
    ]
  }
}
