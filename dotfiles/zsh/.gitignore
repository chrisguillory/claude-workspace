# Machine-private secrets/overrides — the real file lives OUT-OF-TREE at
# ~/.config/zsh.local; these rules are belt-and-suspenders against an in-tree
# habit-drop. (Also enforced at the repo root and by secret-leak-linter.)
local.zsh
zsh.local

# Vendor-installed shell state (per-machine, regenerated locally)
.iterm2_shell_integration.zsh
.iterm2/
.zcompdump*
.zcompcache/
.zsh_history
.zsh_sessions/

# Completions: ignore all, allowlist the universal (machine-agnostic) ones.
# Per-machine snapshots (_claude-*, _document-search, ...) are generated by each
# tool's `install-completions` and must NOT be synced (version-pinned to local CLIs).
completions/*
!completions/README.md
!completions/_cdk
!completions/_gh
